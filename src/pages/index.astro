<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Harry Potter Themed Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet" />
		
		<title>The Great Hall Contribution Duel</title>
		
		<style>
			/* CSS Variables - Magical Color Palette */
			:root {
				--color-burgundy: #740001;
				--color-gold: #D3A625;
				--color-dark-purple: #2A0845;
				--color-midnight-blue: #0E1A40;
				--color-magical-green: #1A472A;
				--color-parchment: #F4E8C1;
				--color-parchment-dark: #D4C4A1;
				
				/* Spell Power Colors (contribution levels 0-4) */
				--spell-level-0: rgba(42, 8, 69, 0.2);
				--spell-level-1: #4A5899;
				--spell-level-2: #8B5CF6;
				--spell-level-3: #D3A625;
				--spell-level-4: #FF6B35;
				
				/* Typography */
				--font-heading: 'Cinzel Decorative', serif;
				--font-body: 'IM Fell English', serif;
			}
			
			/* Reset and Base Styles */
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			
			body {
				font-family: var(--font-body);
				background: linear-gradient(135deg, var(--color-dark-purple) 0%, var(--color-midnight-blue) 50%, #000 100%);
				color: var(--color-parchment);
				min-height: 100vh;
				position: relative;
				overflow-x: hidden;
			}
			
			/* Magical starry background */
			body::before {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background-image: 
					radial-gradient(2px 2px at 20% 30%, white, transparent),
					radial-gradient(2px 2px at 60% 70%, white, transparent),
					radial-gradient(1px 1px at 50% 50%, white, transparent),
					radial-gradient(1px 1px at 80% 10%, white, transparent),
					radial-gradient(2px 2px at 90% 60%, white, transparent),
					radial-gradient(1px 1px at 33% 80%, white, transparent);
				background-size: 200% 200%;
				animation: twinkle 8s ease-in-out infinite;
				opacity: 0.4;
				pointer-events: none;
				z-index: 0;
			}
			
			@keyframes twinkle {
				0%, 100% { opacity: 0.4; }
				50% { opacity: 0.7; }
			}
			
			/* Main Container */
			.container {
				position: relative;
				z-index: 1;
				max-width: 1400px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			
			/* Header - Great Hall Banner */
			header {
				text-align: center;
				margin-bottom: 3rem;
				padding: 2rem 1rem;
				background: linear-gradient(90deg, transparent 0%, rgba(116, 0, 1, 0.3) 20%, rgba(116, 0, 1, 0.5) 50%, rgba(116, 0, 1, 0.3) 80%, transparent 100%);
				border-top: 2px solid var(--color-gold);
				border-bottom: 2px solid var(--color-gold);
				position: relative;
			}
			
			header::before,
			header::after {
				content: '⚡';
				position: absolute;
				font-size: 2rem;
				color: var(--color-gold);
				top: 50%;
				transform: translateY(-50%);
				animation: glow 2s ease-in-out infinite;
			}
			
			header::before { left: 5%; }
			header::after { right: 5%; }
			
			@keyframes glow {
				0%, 100% { opacity: 0.6; text-shadow: 0 0 10px var(--color-gold); }
				50% { opacity: 1; text-shadow: 0 0 20px var(--color-gold), 0 0 30px var(--color-gold); }
			}
			
			h1 {
				font-family: var(--font-heading);
				font-size: clamp(2rem, 5vw, 3.5rem);
				font-weight: 900;
				color: var(--color-gold);
				text-shadow: 
					2px 2px 4px rgba(0, 0, 0, 0.8),
					0 0 20px rgba(211, 166, 37, 0.5),
					0 0 40px rgba(211, 166, 37, 0.3);
				letter-spacing: 0.05em;
				margin-bottom: 0.5rem;
			}
			
			.subtitle {
				font-size: clamp(1rem, 2vw, 1.3rem);
				color: var(--color-parchment);
				font-style: italic;
				opacity: 0.9;
			}
			
			/* Duel Arena Layout */
			.duel-arena {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				gap: 2rem;
				align-items: start;
				margin-bottom: 3rem;
			}
			
			/* VS Badge */
			.vs-badge {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 1rem;
				margin-top: 4rem;
			}
			
			.wands-crossed {
				font-size: 3rem;
				margin-bottom: 0.5rem;
				filter: drop-shadow(0 0 10px var(--color-gold));
			}
			
			.vs-text {
				font-family: var(--font-heading);
				font-size: 2rem;
				font-weight: 900;
				color: var(--color-burgundy);
				text-shadow: 
					0 0 10px rgba(211, 166, 37, 0.8),
					2px 2px 4px rgba(0, 0, 0, 0.8);
				letter-spacing: 0.2em;
			}
			
			/* Wizard Section */
			.wizard-section {
				background: linear-gradient(135deg, rgba(42, 8, 69, 0.4) 0%, rgba(14, 26, 64, 0.4) 100%);
				border: 2px solid var(--color-gold);
				border-radius: 15px;
				padding: 2rem;
				box-shadow: 
					0 10px 30px rgba(0, 0, 0, 0.5),
					inset 0 0 30px rgba(211, 166, 37, 0.1);
				position: relative;
			}
			
			.wizard-section::before {
				content: '';
				position: absolute;
				top: -2px;
				left: -2px;
				right: -2px;
				bottom: -2px;
				background: linear-gradient(45deg, var(--color-gold), var(--color-burgundy), var(--color-gold));
				border-radius: 15px;
				z-index: -1;
				opacity: 0;
				transition: opacity 0.3s ease;
			}
			
			.wizard-section:hover::before {
				opacity: 0.3;
			}
			
			.wizard-title {
				font-family: var(--font-heading);
				font-size: 1.5rem;
				color: var(--color-gold);
				text-align: center;
				margin-bottom: 1.5rem;
				text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
			}
			
			/* Parchment Input Styling */
			.input-group {
				margin-bottom: 1.5rem;
			}
			
			label {
				display: block;
				font-family: var(--font-heading);
				font-size: 1rem;
				color: var(--color-parchment);
				margin-bottom: 0.5rem;
				text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.6);
			}
			
			.parchment-input {
				width: 100%;
				padding: 0.75rem 1rem;
				font-family: var(--font-body);
				font-size: 1rem;
				background: linear-gradient(135deg, var(--color-parchment) 0%, var(--color-parchment-dark) 100%);
				color: #2A0845;
				border: 2px solid #8B7355;
				border-radius: 8px;
				box-shadow: 
					inset 2px 2px 5px rgba(0, 0, 0, 0.2),
					0 4px 10px rgba(0, 0, 0, 0.3);
				transition: all 0.3s ease;
			}
			
			.parchment-input:focus {
				outline: none;
				border-color: var(--color-gold);
				box-shadow: 
					inset 2px 2px 5px rgba(0, 0, 0, 0.2),
					0 0 15px rgba(211, 166, 37, 0.5);
				transform: translateY(-2px);
			}
			
			.parchment-input::placeholder {
				color: rgba(42, 8, 69, 0.5);
				font-style: italic;
			}
			
			/* Battle Button */
			.battle-button-container {
				text-align: center;
				margin: 3rem 0;
			}
			
			.battle-button {
				font-family: var(--font-heading);
				font-size: 1.5rem;
				font-weight: 700;
				padding: 1rem 3rem;
				background: linear-gradient(135deg, var(--color-burgundy) 0%, #5A0001 100%);
				color: var(--color-gold);
				border: 3px solid var(--color-gold);
				border-radius: 50px;
				cursor: pointer;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				box-shadow: 
					0 5px 15px rgba(0, 0, 0, 0.5),
					0 0 20px rgba(211, 166, 37, 0.3);
				transition: all 0.3s ease;
				position: relative;
				overflow: hidden;
			}
			
			.battle-button::before {
				content: '✨';
				position: absolute;
				left: 10%;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.5rem;
				opacity: 0.7;
			}
			
			.battle-button::after {
				content: '✨';
				position: absolute;
				right: 10%;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.5rem;
				opacity: 0.7;
			}
			
			.battle-button:hover {
				background: linear-gradient(135deg, #8B0002 0%, var(--color-burgundy) 100%);
				transform: translateY(-3px) scale(1.05);
				box-shadow: 
					0 10px 25px rgba(0, 0, 0, 0.6),
					0 0 40px rgba(211, 166, 37, 0.6);
			}
			
			.battle-button:active {
				transform: translateY(-1px) scale(1.02);
			}
			
			.battle-button:disabled {
				opacity: 0.6;
				cursor: not-allowed;
				transform: none;
			}
			
			/* Results Section */
			.results-section {
				margin-top: 3rem;
				display: none;
			}
			
			.results-section.visible {
				display: block;
				animation: fadeIn 0.6s ease-in;
			}
			
			@keyframes fadeIn {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}
			
			.results-container {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
			}
			
			.wizard-result {
				background: rgba(42, 8, 69, 0.4);
				border: 2px solid var(--color-gold);
				border-radius: 15px;
				padding: 2rem;
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
			}
			
			.wizard-result.winner {
				border-color: var(--color-spell-level-4);
				box-shadow: 
					0 10px 30px rgba(0, 0, 0, 0.5),
					0 0 30px rgba(255, 107, 53, 0.5);
				animation: pulse 2s ease-in-out infinite;
			}
			
			@keyframes pulse {
				0%, 100% { transform: scale(1); }
				50% { transform: scale(1.02); }
			}
			
			.wizard-name {
				font-family: var(--font-heading);
				font-size: 1.8rem;
				color: var(--color-gold);
				text-align: center;
				margin-bottom: 1rem;
				text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
			}
			
			.winner-badge {
				display: inline-block;
				background: var(--color-spell-level-4);
				color: white;
				padding: 0.3rem 1rem;
				border-radius: 20px;
				font-size: 0.9rem;
				margin-left: 0.5rem;
				font-family: var(--font-body);
				box-shadow: 0 0 15px rgba(255, 107, 53, 0.6);
				animation: sparkle 1.5s ease-in-out infinite;
			}
			
			@keyframes sparkle {
				0%, 100% { box-shadow: 0 0 15px rgba(255, 107, 53, 0.6); }
				50% { box-shadow: 0 0 25px rgba(255, 107, 53, 0.9), 0 0 35px rgba(255, 107, 53, 0.6); }
			}
			
			.spell-power {
				text-align: center;
				margin: 1.5rem 0;
				font-size: 1.2rem;
			}
			
			.spell-power-label {
				display: block;
				color: var(--color-parchment-dark);
				font-size: 0.9rem;
				margin-bottom: 0.3rem;
			}
			
			.spell-power-value {
				display: block;
				font-family: var(--font-heading);
				font-size: 2rem;
				color: var(--color-gold);
				text-shadow: 0 0 10px rgba(211, 166, 37, 0.5);
			}
			
			/* Contribution Grid */
			.contribution-grid {
				margin-top: 1.5rem;
				overflow-x: auto;
				padding: 1rem;
				background: rgba(0, 0, 0, 0.3);
				border-radius: 10px;
			}
			
			.grid-container {
				display: inline-grid;
				grid-template-columns: repeat(53, 12px);
				grid-template-rows: repeat(7, 12px);
				gap: 3px;
				min-width: fit-content;
			}
			
			.grid-cell {
				width: 12px;
				height: 12px;
				border-radius: 2px;
				transition: all 0.2s ease;
			}
			
			.grid-cell:hover {
				transform: scale(1.3);
				z-index: 10;
				position: relative;
			}
			
			.grid-cell[data-level="0"] { background: var(--spell-level-0); }
			.grid-cell[data-level="1"] { background: var(--spell-level-1); box-shadow: 0 0 5px var(--spell-level-1); }
			.grid-cell[data-level="2"] { background: var(--spell-level-2); box-shadow: 0 0 5px var(--spell-level-2); }
			.grid-cell[data-level="3"] { background: var(--spell-level-3); box-shadow: 0 0 8px var(--spell-level-3); }
			.grid-cell[data-level="4"] { background: var(--spell-level-4); box-shadow: 0 0 10px var(--spell-level-4); }
			
			/* Loading State */
			.loading {
				text-align: center;
				padding: 3rem;
				font-size: 1.3rem;
				color: var(--color-gold);
				font-family: var(--font-heading);
			}
			
			.loading::after {
				content: '⚡';
				display: inline-block;
				animation: spin 1.5s linear infinite;
				margin-left: 0.5rem;
				font-size: 2rem;
			}
			
			@keyframes spin {
				from { transform: rotate(0deg); }
				to { transform: rotate(360deg); }
			}
			
			/* Error Message */
			.error-message {
				background: rgba(139, 0, 0, 0.3);
				border: 2px solid #8B0000;
				border-radius: 10px;
				padding: 1.5rem;
				margin: 2rem 0;
				text-align: center;
				color: #FFB3B3;
				font-size: 1.1rem;
			}
			
			/* Responsive Design */
			@media (max-width: 768px) {
				.duel-arena {
					grid-template-columns: 1fr;
					gap: 1.5rem;
				}
				
				.vs-badge {
					order: -1;
					margin-top: 0;
					margin-bottom: 1rem;
				}
				
				.results-container {
					grid-template-columns: 1fr;
				}
				
				h1 {
					font-size: 2rem;
				}
				
				.subtitle {
					font-size: 1rem;
				}
				
				header::before,
				header::after {
					font-size: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<div class="container">
			<header>
				<h1>The Great Hall Contribution Duel</h1>
				<p class="subtitle">Where GitHub Wizards Battle with Spell Power</p>
			</header>
			
			<div class="duel-arena">
				<!-- First Wizard -->
				<div class="wizard-section">
					<h2 class="wizard-title">⚡ First Wizard</h2>
					<div class="input-group">
						<label for="wizard1">Wizard Name (GitHub Username)</label>
						<input 
							type="text" 
							id="wizard1" 
							class="parchment-input" 
							placeholder="e.g., Harry-Potter"
							autocomplete="off"
						/>
					</div>
				</div>
				
				<!-- VS Badge -->
				<div class="vs-badge">
					<div class="wands-crossed">🪄✨🪄</div>
					<div class="vs-text">VS</div>
				</div>
				
				<!-- Second Wizard -->
				<div class="wizard-section">
					<h2 class="wizard-title">⚡ Second Wizard</h2>
					<div class="input-group">
						<label for="wizard2">Wizard Name (GitHub Username)</label>
						<input 
							type="text" 
							id="wizard2" 
							class="parchment-input" 
							placeholder="e.g., HermioneGranger"
							autocomplete="off"
						/>
					</div>
				</div>
			</div>
			
			<!-- Battle Button -->
			<div class="battle-button-container">
				<button class="battle-button" id="castDuel">
					Cast Duel Spell
				</button>
			</div>
			
			<!-- Results Section -->
			<div class="results-section" id="results">
				<!-- Will be populated by JavaScript -->
			</div>
		</div>
		
		<script>
			// API integration and duel logic
			const wizard1Input = document.getElementById('wizard1');
			const wizard2Input = document.getElementById('wizard2');
			const castDuelButton = document.getElementById('castDuel');
			const resultsSection = document.getElementById('results');
			
			// Enter key support
			wizard1Input.addEventListener('keypress', (e) => {
				if (e.key === 'Enter') castDuel();
			});
			
			wizard2Input.addEventListener('keypress', (e) => {
				if (e.key === 'Enter') castDuel();
			});
			
			// Battle button click
			castDuelButton.addEventListener('click', castDuel);
			
			async function castDuel() {
				const wizard1 = wizard1Input.value.trim();
				const wizard2 = wizard2Input.value.trim();
				
				if (!wizard1 || !wizard2) {
					showError('Both wizards must enter the arena!');
					return;
				}
				
				// Disable button and show loading
				castDuelButton.disabled = true;
				resultsSection.innerHTML = '<div class="loading">Summoning magical energies...</div>';
				resultsSection.classList.add('visible');
				
				try {
					// Fetch data for both wizards in parallel
					const [data1, data2] = await Promise.all([
						fetch(`/api/contributions/${wizard1}`).then(res => res.json()),
						fetch(`/api/contributions/${wizard2}`).then(res => res.json())
					]);
					
					// Check for errors
					if (data1.error) throw new Error(`Wizard 1: ${data1.error}`);
					if (data2.error) throw new Error(`Wizard 2: ${data2.error}`);
					
					// Render results
					renderDuelResults(data1, data2);
					
				} catch (error) {
					showError(error.message || 'The duel spell failed! Please try again.');
				} finally {
					castDuelButton.disabled = false;
				}
			}
			
			function renderDuelResults(wizard1Data, wizard2Data) {
				// Calculate spell power (total contributions)
				const power1 = calculateSpellPower(wizard1Data.contributions);
				const power2 = calculateSpellPower(wizard2Data.contributions);
				
				const winner = power1 > power2 ? 1 : power2 > power1 ? 2 : 0;
				
				resultsSection.innerHTML = `
					<div class="results-container">
						<div class="wizard-result ${winner === 1 ? 'winner' : ''}">
							<h3 class="wizard-name">
								${wizard1Data.username}
								${winner === 1 ? '<span class="winner-badge">🏆 Most Powerful Wizard</span>' : ''}
							</h3>
							<div class="spell-power">
								<span class="spell-power-label">Total Spell Power</span>
								<span class="spell-power-value">${power1.toLocaleString()}</span>
							</div>
							<div class="contribution-grid">
								${renderContributionGrid(wizard1Data.contributions)}
							</div>
						</div>
						
						<div class="wizard-result ${winner === 2 ? 'winner' : ''}">
							<h3 class="wizard-name">
								${wizard2Data.username}
								${winner === 2 ? '<span class="winner-badge">🏆 Most Powerful Wizard</span>' : ''}
							</h3>
							<div class="spell-power">
								<span class="spell-power-label">Total Spell Power</span>
								<span class="spell-power-value">${power2.toLocaleString()}</span>
							</div>
							<div class="contribution-grid">
								${renderContributionGrid(wizard2Data.contributions)}
							</div>
						</div>
					</div>
					${winner === 0 ? '<p style="text-align: center; margin-top: 2rem; font-size: 1.3rem; color: var(--color-gold);">⚡ The duel is a tie! Both wizards possess equal power! ⚡</p>' : ''}
				`;
			}
			
			function calculateSpellPower(contributions) {
				// Sum all contribution counts
				// Assuming contributions is an array or object with contribution data
				// This will need to be adjusted based on actual API response structure
				if (!contributions) return 0;
				
				// If it's an object with days
				if (typeof contributions === 'object' && contributions.contributions) {
					return Object.values(contributions.contributions).reduce((sum, day) => sum + (day.count || 0), 0);
				}
				
				// Fallback: try to sum any numeric values
				return 0;
			}
			
			function renderContributionGrid(contributions) {
				// Create a 7x53 grid (7 days x 53 weeks)
				// This is a placeholder - actual implementation depends on API response format
				const cells = [];
				
				// Generate grid cells with random levels for now
				// In production, this should map actual contribution data
				for (let i = 0; i < 371; i++) {
					const level = Math.floor(Math.random() * 5);
					cells.push(`<div class="grid-cell" data-level="${level}" title="Spell cast"></div>`);
				}
				
				return `<div class="grid-container">${cells.join('')}</div>`;
			}
			
			function showError(message) {
				resultsSection.innerHTML = `
					<div class="error-message">
						⚠️ ${message}
					</div>
				`;
				resultsSection.classList.add('visible');
			}
		</script>
	</body>
</html>
